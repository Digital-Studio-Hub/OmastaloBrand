# Ignored by gcloud
# If you would like to add exceptions, add them to .gcloudignore-ignore
# For more information, visit:
# https://cloud.google.com/appengine/docs/standard/nodejs/using-app-yaml

# Git
.git
.gitignore
.gitattributes

# Dependencies (will be reinstalled in cloud build)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts (will be rebuilt in cloud build)
dist/
build/
.next/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Documentation and dev files
*.md
docs/
.replit
replit.md
design_guidelines.md
.local/
.config/

# Testing
coverage/
.nyc_output/

# Environment (secrets handled by Cloud Run service)
.env
.env.local
.env.*.local

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Temporary files
*.tmp
tmp/
temp/
